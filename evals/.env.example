# Agent + sandbox keys for @vercel/agent-eval. Pick ONE agent path:

# --- Vercel AI Gateway (one key for all models, recommended) ---
AI_GATEWAY_API_KEY=
VERCEL_TOKEN=

# --- Direct Anthropic API (no Vercel account needed; uses Docker sandbox) ---
# ANTHROPIC_API_KEY=

# Optional: enables failure classification (skips infra/timeout failures so they re-run)
# Set either AI_GATEWAY_API_KEY or VERCEL_OIDC_TOKEN to enable.
