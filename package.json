{
  "name": "@uinaf/agents",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.9.0",
  "scripts": {
    "lint:actions": "github-actionlint .github/workflows/*.yml",
    "lint:shell": "shellcheck scripts/skills/*.sh scripts/sync/*.sh",
    "lint:skills": "TESSL_REVIEW_MODE=lint ./scripts/skills/review.sh",
    "test:autoreview": "python3 -m unittest discover -s skills/autoreview/tests -p 'test_*.py'",
    "test:sync": "node --test scripts/sync/sync.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint:shell && npm run lint:actions && npm run test:sync && npm run test:autoreview && npm run lint:skills"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "github-actionlint": "1.7.12",
    "typescript": "7.0.2"
  }
}
